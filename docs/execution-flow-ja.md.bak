#### ステップ8: controlsdでの受信と横制御への受け渡し

```python
# controlsd.py の Controls クラス
class Controls:
    def __init__(self):
        # 8-1. SubMasterで modelV2 を購読
        self.sm = messaging.SubMaster([
            'modelV2',           # ← モデル出力
            'carState',
            'longitudinalPlan',
            # その他多数...
        ], poll='selfdriveState')

    def state_control(self):
        # 8-2. 最新のメッセージを取得
        self.sm.update(15)  # 15msタイムアウト

        CS = self.sm['carState']
        model_v2 = self.sm['modelV2']      # ← modelV2メッセージ
        long_plan = self.sm['longitudinalPlan']

        # 8-3. CarControlメッセージの作成
        CC = car.CarControl.new_message()
        CC.enabled = self.sm['selfdriveState'].enabled
        CC.latActive = 横制御が有効か判定
        CC.longActive = 縦制御が有効か判定

        # 8-4. 横制御の更新
        # ★ここでmodelV2のdesiredCurvatureを使用★
        new_desired_curvature = model_v2.action.desiredCurvature if CC.latActive else self.curvature

        # 曲率の制限（急激な変化を抑制）
        self.desired_curvature, curvature_limited = clip_curvature(
            CS.vEgo,
            self.desired_curvature,    # 前回の曲率
            new_desired_curvature,     # 今回の目標曲率
            lp.roll                     # ロール角
        )

        # actuatorsに設定
        actuators.curvature = self.desired_curvature

        # 8-5. LatControlを呼び出し
        steer, steeringAngleDeg, lac_log = self.LaC.update(
            CC.latActive,
            CS,
            self.VM,                      # VehicleModel
            lp,                           # liveParameters
            self.steer_limited_by_controls,
            self.desired_curvature,       # ← ★これがモデルからの目標曲率★
            self.calibrated_pose,
            curvature_limited
        )

        # 8-6. 出力トルク/角度を設定
        actuators.torque = float(steer)
        actuators.steeringAngleDeg = float(steeringAngleDeg)

        return CC, lac_log
```

---

#### ステップ9: 横制御PIDでの処理（最終段階）

```python
# latcontrol_torque.py の LatControlTorque クラス
class LatControlTorque:
    def update(self, active, CS, VM, params, steer_limited_by_controls,
               desired_curvature, calibrated_pose, curvature_limited):

        if not active:
            return 0.0, 0.0, pid_log

        # 9-1. 現在の曲率を計算
        actual_curvature = -VM.calc_curvature(
            math.radians(CS.steeringAngleDeg - params.angleOffsetDeg),
            CS.vEgo,
            params.roll
        )

        # 9-2. 曲率から横加速度へ変換（物理の公式）
        desired_lateral_accel = desired_curvature * CS.vEgo ** 2  # ← ★モデル出力を使用★
        actual_lateral_accel = actual_curvature * CS.vEgo ** 2

        # 9-3. 低速補正
        low_speed_factor = np.interp(CS.vEgo, LOW_SPEED_X, LOW_SPEED_Y)**2
        setpoint = desired_lateral_accel + low_speed_factor * desired_curvature
        measurement = actual_lateral_accel + low_speed_factor * actual_curvature

        # 9-4. 横加速度からトルクへ変換（車両固有の関数）
        torque_from_setpoint = self.torque_from_lateral_accel(setpoint, ...)
        torque_from_measurement = self.torque_from_lateral_accel(measurement, ...)

        # 9-5. PID制御で追従
        error = torque_from_setpoint - torque_from_measurement
        output_torque = self.pid.update(
            error,
            feedforward=ff,
            speed=CS.vEgo,
            freeze_integrator=freeze_integrator
        )

        return -output_torque, 0.0, pid_log
```

---

#### ステップ10: CANバスへの出力

```python
# card.py の Car クラス
class Car:
    def controls_update(self, CS, CC):
        # 10-1. CarControllerを呼び出し
        self.last_actuators_output, can_sends = self.CI.apply(CC, now_nanos)

        # 10-2. CANメッセージ送信
        self.pm.send('sendcan', can_list_to_can_capnp(can_sends, msgtype='sendcan'))

# carcontroller.py（車種固有）の例: Toyota
class CarController:
    def update(self, CC, CS, now_nanos):
        actuators = CC.actuators

        # 10-3. トルクをCANメッセージに変換
        new_torque = int(round(actuators.torque * self.params.STEER_MAX))

        # 10-4. レート制限・安全チェック
        apply_torque = apply_meas_steer_torque_limits(
            new_torque,
            self.last_torque,
            CS.out.steeringTorqueEps,
            self.params
        )

        # 10-5. CANメッセージ作成
        can_sends = []
        steer_command = toyotacan.create_steer_command(
            self.packer,
            apply_torque,
            apply_steer_req
        )
        can_sends.append(steer_command)

        return actuators, can_sends
```

