#### ステップ7: modelV2メッセージの配信

```python
# modeld.py の main() メインループ続き
def main():
    # 7-1. modelV2メッセージの作成
    modelv2_send = messaging.new_message('modelV2')

    # 7-2. モデル出力をメッセージに詰める
    fill_model_msg(
        modelv2_send.modelV2,
        model_output,
        publish_state,
        meta_main.frame_id,
        meta_main.timestamp_eof,
        meta_extra.timestamp_eof,
        frame_drop_ratio,
        new_action,           # ← desired_curvature と desired_accel を含む
        v_ego
    )

    # fill_model_msg() の主な処理:
    #   - modelV2.action.desiredCurvature = new_action.desiredCurvature
    #   - modelV2.action.desiredAcceleration = new_action.desiredAcceleration
    #   - modelV2.position.x = model_output['plan'][0, :, Plan.POSITION][:, 0]
    #   - modelV2.velocity.x = model_output['plan'][0, :, Plan.VELOCITY][:, 0]
    #   - modelV2.acceleration.x = model_output['plan'][0, :, Plan.ACCELERATION][:, 0]
    #   - modelV2.laneLines = model_output['lane_lines']
    #   - modelV2.roadEdges = model_output['road_edges']
    #   - その他多数の情報

    # 7-3. msgqで配信
    pm.send('modelV2', modelv2_send)

    # 配信先:
    #   - controlsd: action.desiredCurvature を使用（横制御）
    #   - plannerd: position, velocity, acceleration を使用（縦制御のMPC）
    #   - selfdrived: meta情報を使用（状態管理）
    #   - ui: 表示用
```

**modelV2メッセージの構造**:
```python
modelV2 = {
    'frameId': 12345,
    'timestampEof': 1234567890,
    'frameDropPerc': 0.0,

    # ★横制御で使用
    'action': {
        'desiredCurvature': 0.05,        # 1/m（曲率）
        'desiredAcceleration': 0.5,      # m/s²
        'shouldStop': False
    },

    # 縦制御で使用（plannerd経由）
    'position': {'x': [0, 2.5, 5.2, ...], 'y': [...], 'z': [...]},  # 33ポイント
    'velocity': {'x': [10, 10.5, 11, ...], 'y': [...], 'z': [...]},
    'acceleration': {'x': [0.5, 0.4, ...], 'y': [...], 'z': [...]},

    # 車線情報
    'laneLines': [...],          # 4本の車線
    'laneLineProbs': [...],      # 確信度
    'roadEdges': [...],          # 2本の道路エッジ

    # メタ情報
    'meta': {
        'engagedProb': 0.95,
        'disengagePredictions': {...},
        'hardBrakePredicted': 0.01,
    }
}
```

